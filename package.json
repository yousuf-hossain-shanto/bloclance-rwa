{
  "name": "surgexrp",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter web exec playwright test",
    "test:e2e:install": "pnpm --filter web exec playwright install chromium",
    "type-check": "turbo run type-check",
    "format": "biome format --write .",
    "check": "biome check .",
    "db:push": "pnpm --filter @surgexrp/db db:push",
    "db:seed": "pnpm --filter @surgexrp/db db:seed",
    "db:generate": "pnpm --filter @surgexrp/db generate"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "lefthook": "^1.8.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
